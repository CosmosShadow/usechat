{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "composite": true,
    "declarationMap": true
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "dist",
    "src/**/*.test.ts",
    "src/__tests__/**/*.ts"
  ],
  "references": [
    {
      "path": "../core"
    },
    {
      "path": "../model-provider"
    }
  ]
}
