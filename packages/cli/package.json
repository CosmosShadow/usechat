{
  "name": "@shennian/usechat",
  "version": "0.1.0",
  "private": true,
  "description": "UseChat command line interface.",
  "type": "module",
  "bin": {
    "usechat": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/fix-bin-mode.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@shennian/usechat-core": "workspace:*",
    "@shennian/usechat-model-provider": "workspace:*"
  }
}
