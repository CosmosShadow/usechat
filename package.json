{
  "name": "usechat-workspace",
  "version": "0.0.0-private",
  "private": true,
  "description": "UseChat — Computer Use for messaging agents.",
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "corepack pnpm -r build",
    "check": "corepack pnpm typecheck && corepack pnpm test",
    "helper-runtime:build": "corepack pnpm --dir helper-runtime build",
    "helper-runtime:build:mac": "corepack pnpm --dir helper-runtime build:mac",
    "helper-runtime:build:native:mac": "corepack pnpm --dir helper-runtime build:native:mac",
    "helper-runtime:build:native:win": "corepack pnpm --dir helper-runtime build:native:win",
    "helper-runtime:build:win": "corepack pnpm --dir helper-runtime build:win",
    "helper-runtime:validate": "corepack pnpm --dir helper-runtime validate",
    "release:private:packages": "corepack pnpm release:npm:pack",
    "smoke:wechat:abc": "node scripts/wechat-abc-smoke.mjs --chat ABC",
    "smoke:wechat:abc:attachments": "node scripts/wechat-abc-attachment-smoke.mjs --chat ABC",
    "smoke:wechat:abc:attachments:windows-task": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/windows-run-wechat-abc-smoke-task.ps1 -Chat ABC -TaskName UseChatWechatAbcAttachmentSmoke -ScriptName wechat-abc-attachment-smoke.mjs -WaitSeconds 360",
    "smoke:wechat:abc:windows-task": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/windows-run-wechat-abc-smoke-task.ps1 -Chat ABC",
    "test": "corepack pnpm -r --if-present test",
    "typecheck": "corepack pnpm -r --if-present typecheck",
    "release:npm:pack": "node scripts/release-npm-packages.mjs",
    "release:npm:dry-run": "node scripts/publish-npm-packages.mjs --dry-run",
    "release:npm:publish": "node scripts/publish-npm-packages.mjs --publish"
  },
  "devDependencies": {
    "@types/node": "^20.19.9",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18"
  }
}
